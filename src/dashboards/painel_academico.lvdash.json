{
  "datasets": [
    {
      "name": "ds_counters",
      "displayName": "Indicadores Gerais",
      "queryLines": [
        "SELECT ",
        "  (SELECT COUNT(*) FROM workspace.sistema_academico.alunos WHERE status = 'ativo') as total_alunos_ativos, ",
        "  (SELECT COUNT(DISTINCT aluno_id) FROM workspace.sistema_academico.matriculas WHERE semestre = '2025/1' AND situacao != 'trancado') as alunos_cursando, ",
        "  (SELECT ROUND(SUM(CASE WHEN situacao = 'aprovado' THEN 1 ELSE 0 END) * 100.0 / COUNT(*), 1) FROM workspace.sistema_academico.matriculas WHERE situacao != 'trancado') as taxa_aprovacao, ",
        "  (SELECT ROUND(AVG(nota_final), 2) FROM workspace.sistema_academico.matriculas WHERE situacao != 'trancado') as media_geral, ",
        "  (SELECT COUNT(*) FROM workspace.sistema_academico.gold_alunos_em_risco WHERE nivel_risco = 'ALTO') as alunos_risco_alto, ",
        "  (SELECT COUNT(*) FROM workspace.sistema_academico.gold_alunos_em_risco WHERE nivel_risco = 'MÉDIO') as alunos_risco_medio "
      ]
    },
    {
      "name": "ds_top_reprovacao",
      "displayName": "Top Reprovacao",
      "queryLines": [
        "SELECT CONCAT(disciplina_codigo, ' - ', disciplina_nome) as disciplina, ",
        "  departamento_sigla, semestre, ",
        "  ROUND(100.0 - taxa_aprovacao, 1) as taxa_reprovacao, ",
        "  media_nota ",
        "FROM workspace.sistema_academico.gold_desempenho_disciplina ",
        "ORDER BY taxa_reprovacao DESC "
      ]
    },
    {
      "name": "ds_dist_notas",
      "displayName": "Distribuicao Notas",
      "queryLines": [
        "SELECT CAST(FLOOR(nota_final) AS INT) as faixa, ",
        "  CASE WHEN nota_final >= 6.0 THEN 'Aprovado' ELSE 'Reprovado' END as resultado, ",
        "  semestre, ",
        "  COUNT(*) as total ",
        "FROM workspace.sistema_academico.matriculas ",
        "WHERE nota_final IS NOT NULL AND situacao != 'trancado' ",
        "GROUP BY FLOOR(nota_final), CASE WHEN nota_final >= 6.0 THEN 'Aprovado' ELSE 'Reprovado' END, semestre ",
        "ORDER BY faixa "
      ]
    },
    {
      "name": "ds_evolucao",
      "displayName": "Evolucao por Semestre",
      "queryLines": [
        "SELECT semestre, ",
        "  ROUND(AVG(taxa_aprovacao), 1) as taxa_aprovacao, ",
        "  ROUND(AVG(media_nota), 2) as media_nota, ",
        "  SUM(total_alunos) as total_matriculas ",
        "FROM workspace.sistema_academico.gold_desempenho_disciplina ",
        "GROUP BY semestre ORDER BY semestre "
      ]
    },
    {
      "name": "ds_aprovacao_curso",
      "displayName": "Aprovacao por Curso",
      "queryLines": [
        "SELECT curso_sigla, semestre, ",
        "  ROUND(AVG(cra_acumulado), 2) as cra_medio, ",
        "  COUNT(DISTINCT aluno_id) as total_alunos ",
        "FROM workspace.sistema_academico.gold_desempenho_aluno ",
        "GROUP BY curso_sigla, semestre ORDER BY cra_medio DESC "
      ]
    },
    {
      "name": "ds_risco_dist",
      "displayName": "Distribuicao Risco",
      "queryLines": [
        "SELECT nivel_risco, COUNT(*) as total ",
        "FROM workspace.sistema_academico.gold_alunos_em_risco ",
        "GROUP BY nivel_risco "
      ]
    },
    {
      "name": "ds_risco_top",
      "displayName": "Top 20 Risco",
      "queryLines": [
        "SELECT aluno_nome, curso_sigla, media_atual, freq_atual, ",
        "  cra_historico, total_reprovacoes_historico, score_risco, nivel_risco ",
        "FROM workspace.sistema_academico.gold_alunos_em_risco ",
        "ORDER BY score_risco DESC LIMIT 20 "
      ]
    },
    {
      "name": "ds_risco_curso",
      "displayName": "Risco por Curso",
      "queryLines": [
        "SELECT curso_sigla, nivel_risco, COUNT(*) as total ",
        "FROM workspace.sistema_academico.gold_alunos_em_risco ",
        "GROUP BY curso_sigla, nivel_risco ORDER BY curso_sigla "
      ]
    },
    {
      "name": "ds_risco_scatter",
      "displayName": "Risco Scatter",
      "queryLines": [
        "SELECT aluno_nome, curso_sigla, media_atual, freq_atual, score_risco, nivel_risco ",
        "FROM workspace.sistema_academico.gold_alunos_em_risco "
      ]
    },
    {
      "name": "ds_depto",
      "displayName": "Aprovacao por Departamento",
      "queryLines": [
        "SELECT departamento_sigla, ",
        "  ROUND(AVG(taxa_aprovacao), 1) as taxa_aprovacao, ",
        "  ROUND(AVG(media_nota), 2) as media_nota, ",
        "  SUM(total_alunos) as total_matriculas ",
        "FROM workspace.sistema_academico.gold_desempenho_disciplina ",
        "GROUP BY departamento_sigla ORDER BY taxa_aprovacao "
      ]
    },
    {
      "name": "ds_depto_semestre",
      "displayName": "Departamento por Semestre",
      "queryLines": [
        "SELECT departamento_sigla, semestre, ",
        "  ROUND(AVG(taxa_aprovacao), 1) as taxa_aprovacao ",
        "FROM workspace.sistema_academico.gold_desempenho_disciplina ",
        "GROUP BY departamento_sigla, semestre ORDER BY semestre "
      ]
    },
    {
      "name": "ds_heatmap",
      "displayName": "Notas Disciplinas Dificeis",
      "queryLines": [
        "SELECT CONCAT(disciplina_codigo, ' - ', disciplina_nome) as disciplina, ",
        "  semestre, media_nota, taxa_aprovacao ",
        "FROM workspace.sistema_academico.gold_desempenho_disciplina ",
        "WHERE disciplina_codigo IN ( ",
        "  SELECT disciplina_codigo FROM workspace.sistema_academico.gold_desempenho_disciplina ",
        "  GROUP BY disciplina_codigo ORDER BY AVG(taxa_aprovacao) LIMIT 10 ",
        ") ORDER BY disciplina, semestre "
      ]
    }
  ],
